APP_NAME="Scuola Guida"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=scuola_guida
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Le notifiche email del flusso iscrizioni sono fire-and-forget e vengono
# accodate sulla coda 'emails'. In sviluppo lanciare il worker con:
#   php artisan queue:work --queue=emails
QUEUE_CONNECTION=database

# Cache: CACHE_ENABLED=false disabilita completamente (driver null, tutto ricalcolato live).
# CACHE_STORE sceglie il backend quando CACHE_ENABLED=true.
# In produzione: CACHE_ENABLED=true + CACHE_STORE=redis.
# In CI/ambienti senza Redis: CACHE_ENABLED=true + CACHE_STORE=file (o database).
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

#REDIS_CLIENT=phpredis# richiede php_redis (non disponibile in Laragon default)
REDIS_CLIENT=predis# pure PHP (nessuna estensione aggiuntiva richiesta)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1

# --- Email (sviluppo: Mailtrap) ---
# Per testare le email del flusso iscrizioni in locale, creare un inbox su
# https://mailtrap.io e inserire qui le credenziali SMTP personali.
# Per evitare l'invio (es. in CI), usare MAIL_MAILER=log.
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null# sostituire con credenziali Mailtrap personali
MAIL_PASSWORD=null# sostituire con credenziali Mailtrap personali
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@scuolaguida.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Backup (spatie/laravel-backup) ---
# Disco locale dedicato ai backup (definito in config/filesystems.php come 'backups')
BACKUP_DISK=backups
# Retention policy (configurabile, valori di default ragionevoli per produzione)
BACKUP_KEEP_ALL_DAYS=7
BACKUP_KEEP_DAILY=16
BACKUP_KEEP_WEEKLY=8
BACKUP_KEEP_MONTHLY=4
# Password archivio zip (opzionale, null = disabilitata)
BACKUP_ARCHIVE_PASSWORD=
# Notifica su successo backup (default false per non generare rumore)
BACKUP_NOTIFY_ON_SUCCESS=false
# Email per notifiche backup fallito (default = MAIL_FROM_ADDRESS)
BACKUP_NOTIFICATION_EMAIL=

# Disco S3-compatibile opzionale per backup remoto (lasciare vuoto se non usato)
# Se configurato, aggiungere 'backup-s3' alla lista disks in config/backup.php
# BACKUP_S3_BUCKET=
# BACKUP_S3_KEY=
# BACKUP_S3_SECRET=
# BACKUP_S3_REGION=eu-west-1
# BACKUP_S3_ENDPOINT=

# --- Autenticazione a due fattori ---
# Impostare a false per disabilitare il 2FA su tutta la piattaforma (es. ambienti di sviluppo)
TWO_FACTOR_ENABLED=true

VITE_APP_NAME="${APP_NAME}"

# --- Web Push Notifications (VAPID) ---
# Chiavi per le notifiche push native (browser chiuso / dispositivo bloccato).
# Genera le chiavi in produzione con: php artisan webpush:vapid
# (richiede OpenSSL con supporto EC; in Laragon/Windows usare: ! node -e "...")
# Le chiavi NON devono cambiare dopo il primo deploy: cambiarle invalida
# tutte le subscription esistenti e richiede una nuova iscrizione degli utenti.
#
# VAPID_SUBJECT: URI del sito (https://...) o indirizzo email del responsabile.
# Usare sempre https:// in produzione.
VAPID_PUBLIC_KEY=         # chiave pubblica base64url (87 caratteri)
VAPID_PRIVATE_KEY=        # chiave privata base64url (43 caratteri)
VAPID_SUBJECT=mailto:admin@scuolaguida.local

# --- Dati autoscuola (usati nel riepilogo PDF guide pratiche) ---
# Intestazione e footer del PDF attestazione generato per le sessioni di guida
DRIVING_SCHOOL_NAME="Scuola Guida"
DRIVING_SCHOOL_ADDRESS=
DRIVING_SCHOOL_PHONE=
DRIVING_SCHOOL_EMAIL=
DRIVING_SCHOOL_LICENSE=         # numero autorizzazione MIT
